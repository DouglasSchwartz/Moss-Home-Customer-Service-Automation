# ---- Anthropic (Claude) ----
# Created under the Moss Anthropic account (Friday with Jacq)
ANTHROPIC_API_KEY=

# ---- Smartsheet ----
# Personal access token "NBN Customer Service Automation" (Smartsheet > Personal Settings > API Access)
# Alias also accepted: SMARTSHEET_ACCESS_TOKEN
SMARTSHEET_API_TOKEN=
# Numeric sheet ID for "MASTER: Open Orders Sheet".
# Alias also accepted: SMARTSHEET_OPEN_ORDERS_SHEET_ID
# Verify via GET /api/smartsheet/schema or `npm run sync-columns`.
SMARTSHEET_SHEET_ID=
# Optional: defaults to https://api.smartsheet.com/2.0
# SMARTSHEET_API_BASE_URL=

# ---- Additional sheets (multi-sheet order search + fabric flow) ----
# All of these have working defaults baked into lib/sheets-config.ts
# (verified against the live token Jun 2026). Only set them to override.
# SMARTSHEET_BASICS_SHEET_ID=2663054034554756
# SMARTSHEET_ARCHIVE_SHEET_IDS=6190562341244804,4648954697305988,3786789735059332,7824661899333508
# SMARTSHEET_BARCLOUD_SHEET_ID=2099244581212036
# SMARTSHEET_FABRIC_MASTER_SHEET_ID=7520330970359684
# Warehouse contact for dye-lot confirmations:
# FABRIC_WAREHOUSE_EMAIL=josediaz@mosshomeusa.com

# ---- Supabase (audit log) — OPTIONAL, skipped for v1 ----
# The app runs fine without these; decisions are visible in n8n execution
# logs, Vercel function logs, and Gmail labels. If we ever want a durable
# audit trail / dashboard, create a DEDICATED Moss Supabase project (not
# Expert AI Labs) and set these.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ---- Shared secret with n8n ----
# Generate with: openssl rand -hex 32
# Must match the n8n "Moss Home - Process API" header auth credential.
PROCESS_API_SECRET=

# ---- Safety ----
# true  = compute everything, log everything, but n8n must NOT send (label-only dry run)
# false = live; n8n sends when reply_mode === "auto_reply"
DRY_RUN=true

# ---- Optional model overrides ----
# EXTRACT_MODEL=claude-haiku-4-5
# GENERATE_MODEL=claude-sonnet-4-6
