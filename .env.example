# ---- Anthropic (Claude) ----
# Created under the Moss Anthropic account (Friday with Jacq)
ANTHROPIC_API_KEY=

# ---- Smartsheet ----
# Personal access token "NBN Customer Service Automation" (Smartsheet > Personal Settings > API Access)
SMARTSHEET_API_TOKEN=
# Numeric sheet ID for "MASTER: Open Orders Sheet".
# Run `npm run sync-columns` to list all sheets visible to the token and verify this ID.
SMARTSHEET_SHEET_ID=

# ---- Supabase (audit log) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Shared secret with n8n ----
# Generate with: openssl rand -hex 32
# Must match the n8n "Moss Home - Process API" header auth credential.
PROCESS_API_SECRET=

# ---- Safety ----
# true  = compute everything, log everything, but n8n must NOT send (label-only dry run)
# false = live; n8n sends when reply_mode === "auto_reply"
DRY_RUN=true

# ---- Optional model overrides ----
# EXTRACT_MODEL=claude-haiku-4-5
# GENERATE_MODEL=claude-sonnet-4-6
